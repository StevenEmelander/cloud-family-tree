{
  "name": "cloud-family-tree",
  "version": "0.1.1",
  "private": true,
  "description": "Modern, open-source genealogy platform for families",
  "license": "MIT",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "deploy": "bash scripts/deploy.sh",
    "deploy:backend": "bash scripts/deploy.sh --backend-only",
    "deploy:frontend": "bash scripts/deploy.sh --frontend-only"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.0.0",
    "@types/node": "^20.11.0",
    "esbuild": "^0.27.3",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.1"
}
